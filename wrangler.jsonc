{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stephanbuilds-com",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2025-10-01",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
  },
  "routes": [
    {
      "pattern": "stephanbuilds.com",
      "custom_domain": true,
    },
    {
      "pattern": "stephandevries.com",
      "custom_domain": true,
    },
  ],
  "observability": {
    "enabled": true,
  },
}
